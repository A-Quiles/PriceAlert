# ============================================================
# PriceAlert — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Angular (injected at build time via environment.ts) ───────
# These must be set as Vercel environment variables for production
# For local dev, update src/environments/environment.ts directly
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
API_URL=https://your-project.vercel.app

# ── SMTP / Email ──────────────────────────────────────────────
# For Gmail: use App Password (not your normal password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=PriceAlert <noreply@yourapp.com>

# Alternative: Resend API (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── Vercel Cron Security ──────────────────────────────────────
# A random secret to authenticate cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── Web Scraping (optional but recommended for production) ─────
# ScraperAPI key to avoid Amazon bot detection
# Sign up at: https://www.scraperapi.com/ (free tier: 1,000 req/month)
SCRAPER_API_KEY=your_scraperapi_key_here
